{
  "name": "git-sets",
  "displayName": "Git Sets",
  "description": "Create and manage Git Sets — collections of git worktrees — from inside VS Code",
  "version": "0.3.1",
  "publisher": "seanodell",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/seanodell/vscode-gitsets"
  },
  "homepage": "https://github.com/seanodell/vscode-gitsets#readme",
  "bugs": {
    "url": "https://github.com/seanodell/vscode-gitsets/issues"
  },
  "keywords": [
    "git",
    "worktree",
    "workspace",
    "multi-repo",
    "branch"
  ],
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "views": {
      "explorer": [
        {
          "id": "gitsets.view",
          "name": "Git Sets",
          "icon": "$(git-branch)"
        }
      ]
    },
    "commands": [
      {
        "command": "gitsets.openRepository",
        "title": "Open Repository",
        "category": "Git Sets",
        "icon": "$(window)"
      },
      {
        "command": "gitsets.expandAll",
        "title": "Expand All",
        "category": "Git Sets",
        "icon": "$(expand-all)"
      },
      {
        "command": "gitsets.refresh",
        "title": "Refresh",
        "category": "Git Sets",
        "icon": "$(refresh)"
      },
      {
        "command": "gitsets.openSettings",
        "title": "Open Settings",
        "category": "Git Sets",
        "icon": "$(gear)"
      },
      {
        "command": "gitsets.addSet",
        "title": "New Set",
        "category": "Git Sets",
        "icon": "$(add)"
      },
      {
        "command": "gitsets.openSet",
        "title": "Open Set",
        "category": "Git Sets",
        "icon": "$(window)"
      },
      {
        "command": "gitsets.addFavorite",
        "title": "Add to Favorites",
        "category": "Git Sets",
        "icon": "$(heart)"
      },
      {
        "command": "gitsets.removeFavorite",
        "title": "Remove from Favorites",
        "category": "Git Sets",
        "icon": "$(heart-filled)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "gitsets.expandAll",
          "when": "view == gitsets.view",
          "group": "navigation@1"
        },
        {
          "command": "gitsets.refresh",
          "when": "view == gitsets.view",
          "group": "navigation@2"
        },
        {
          "command": "gitsets.openSettings",
          "when": "view == gitsets.view",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "gitsets.openRepository",
          "when": "view == gitsets.view && (viewItem == repository || viewItem == repository.favorited)",
          "group": "inline"
        },
        {
          "command": "gitsets.addSet",
          "when": "view == gitsets.view && viewItem == setsSection",
          "group": "inline"
        },
        {
          "command": "gitsets.openSet",
          "when": "view == gitsets.view && viewItem == set",
          "group": "inline"
        },
        {
          "command": "gitsets.openSet",
          "when": "view == gitsets.view && viewItem == set.favorited",
          "group": "inline"
        },
        {
          "command": "gitsets.addFavorite",
          "when": "view == gitsets.view && (viewItem == repository || viewItem == set)",
          "group": "inline"
        },
        {
          "command": "gitsets.removeFavorite",
          "when": "view == gitsets.view && (viewItem == repository.favorited || viewItem == set.favorited)",
          "group": "inline"
        }
      ],
      "commandPalette": [
        {
          "command": "gitsets.openRepository",
          "when": "false"
        },
        {
          "command": "gitsets.expandAll",
          "when": "view == gitsets.view"
        },
        {
          "command": "gitsets.refresh",
          "when": "view == gitsets.view"
        },
        {
          "command": "gitsets.addSet",
          "when": "view == gitsets.view"
        },
        {
          "command": "gitsets.openSet",
          "when": "false"
        },
        {
          "command": "gitsets.addFavorite",
          "when": "false"
        },
        {
          "command": "gitsets.removeFavorite",
          "when": "false"
        }
      ]
    },
    "configuration": {
      "title": "Git Sets",
      "properties": {
        "gitsets.rootFolder": {
          "type": "string",
          "default": "",
          "scope": "machine-overridable",
          "markdownDescription": "Root folder to scan for git repositories and sets. Accepts an absolute path or the shorthands `~`, `${userHome}`, and `${env:VAR}`."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "tsc -p ./",
    "test": "tsc -p ./ && node --test out/tree.test.js"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.9.2",
    "typescript": "^5.5.0"
  }
}
