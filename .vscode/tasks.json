{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "type": "shell",
      "command": "${workspaceFolder}/node_modules/.bin/tsc -p ./",
      "options": {
        "env": {
          "PATH": "${env:HOME}/.local/share/mise/shims:${env:PATH}"
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$tsc"
    }
  ]
}
